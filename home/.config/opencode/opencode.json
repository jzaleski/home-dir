{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "llama.cpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama.cpp (localhost)",
      "options": {
        "baseURL": "http://localhost:8081/v1"
      },
      "models": {
        "jzaleski/coder": {
          "name": "coder",
          "limit": {
            "context": 65536,
            "input": 57344,
            "output": 8192
          },
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          }
        }
      }
    }
  }
}
